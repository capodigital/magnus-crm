generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id @default(cuid())
  email         String?      @unique
  password      String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  image         String?
  role          Role         @default(USUARIO)
  emailVerified DateTime?
  name          String?
  phone         String?      @db.VarChar(20)
  accounts      Account[]
  sessions      Session[]
  memberships   Membership[]

  @@map("users")
}

enum Role {
  ADMIN
  USUARIO
  SUPER_ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum TenantMode {
  SAAS
  WHITE_LABEL
}

enum TenantBillingMode {
  PLATFORM_PLUS_META
  META_ONLY
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum TenantRole {
  OWNER
  ADMIN
  MEMBER
  AGENT
  VIEWER
}

enum DomainKind {
  PLATFORM_SUBDOMAIN
  CUSTOM_DOMAIN
  WILDCARD_DOMAIN
}

model Tenant {
  id          String            @id @default(cuid())
  slug        String            @unique
  name        String
  mode        TenantMode        @default(SAAS)
  billingMode TenantBillingMode @default(PLATFORM_PLUS_META)
  status      TenantStatus      @default(ACTIVE)
  timezone    String?           @default("UTC")
  locale      String?           @default("es-419")
  planCode    String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  domains     TenantDomain[]
  branding    TenantBranding?
  memberships Membership[]

  @@index([status, createdAt])
  @@map("tenants")
}

model TenantDomain {
  id             String     @id @default(cuid())
  tenantId       String
  host           String     @unique
  kind           DomainKind @default(CUSTOM_DOMAIN)
  isPrimary      Boolean    @default(false)
  verifiedAt     DateTime?
  sslStatus      String?
  dnsTarget      String?
  redirectToHost String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isPrimary])
  @@map("tenant_domains")
}

model TenantBranding {
  id             String   @id @default(cuid())
  tenantId       String   @unique
  appName        String
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String?
  secondaryColor String?
  supportEmail   String?
  fromName       String?
  emailDomain    String?
  customCss      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_branding")
}

model Membership {
  id        String     @id @default(cuid())
  tenantId  String
  userId    String
  role      TenantRole
  isOwner   Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId, role])
  @@map("memberships")
}
