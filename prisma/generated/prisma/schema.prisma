generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String         @id @default(cuid())
  email                 String?        @unique
  password              String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  image                 String?
  role                  Role           @default(USUARIO)
  emailVerified         DateTime?
  name                  String?
  phone                 String?        @db.VarChar(20)
  accounts              Account[]
  sessions              Session[]
  memberships           Membership[]
  ownedLeads            Lead[]         @relation("LeadOwner")
  assignedConversations Conversation[] @relation("ConversationAssignee")

  @@map("users")
}

enum Role {
  ADMIN
  USUARIO
  SUPER_ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum TenantMode {
  SAAS
  WHITE_LABEL
}

enum TenantBillingMode {
  PLATFORM_PLUS_META
  META_ONLY
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum TenantRole {
  OWNER
  ADMIN
  MEMBER
  AGENT
  VIEWER
}

enum DomainKind {
  PLATFORM_SUBDOMAIN
  CUSTOM_DOMAIN
  WILDCARD_DOMAIN
}

enum LeadSourceChannel {
  WHATSAPP
  MANUAL
  IMPORT
  API
}

enum LeadStatus {
  OPEN
  WON
  LOST
  ARCHIVED
}

enum ChannelType {
  WHATSAPP
}

enum ConversationStatus {
  OPEN
  PENDING
  CLOSED
  SPAM
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageKind {
  TEXT
  IMAGE
  DOCUMENT
  AUDIO
  VIDEO
  TEMPLATE
  SYSTEM
}

enum WhatsappWebhookEventType {
  MESSAGE
  STATUS
  UNKNOWN
}

enum WhatsappWebhookProcessingStatus {
  PENDING
  PROCESSED
  IGNORED
  FAILED
}

model Tenant {
  id                    String                 @id @default(cuid())
  slug                  String                 @unique
  name                  String
  mode                  TenantMode             @default(SAAS)
  billingMode           TenantBillingMode      @default(PLATFORM_PLUS_META)
  status                TenantStatus           @default(ACTIVE)
  timezone              String?                @default("UTC")
  locale                String?                @default("es-419")
  planCode              String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  domains               TenantDomain[]
  branding              TenantBranding?
  memberships           Membership[]
  contacts              Contact[]
  leads                 Lead[]
  conversations         Conversation[]
  messages              Message[]
  whatsappPhoneNumbers  WhatsappPhoneNumber[]
  whatsappWebhookEvents WhatsappWebhookEvent[]
  pipelines             Pipeline[]
  pipelineStages        PipelineStage[]

  @@index([status, createdAt])
  @@map("tenants")
}

model TenantDomain {
  id             String     @id @default(cuid())
  tenantId       String
  host           String     @unique
  kind           DomainKind @default(CUSTOM_DOMAIN)
  isPrimary      Boolean    @default(false)
  verifiedAt     DateTime?
  sslStatus      String?
  dnsTarget      String?
  redirectToHost String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isPrimary])
  @@map("tenant_domains")
}

model TenantBranding {
  id             String   @id @default(cuid())
  tenantId       String   @unique
  appName        String
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String?
  secondaryColor String?
  supportEmail   String?
  fromName       String?
  emailDomain    String?
  customCss      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_branding")
}

model Membership {
  id        String     @id @default(cuid())
  tenantId  String
  userId    String
  role      TenantRole
  isOwner   Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId, role])
  @@map("memberships")
}

model Contact {
  id              String         @id @default(cuid())
  tenantId        String
  firstName       String?
  lastName        String?
  fullName        String?
  email           String?
  phoneE164       String?
  whatsappWaId    String?
  normalizedPhone String?
  source          String?
  tags            String[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  version         Int            @default(1)
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leads           Lead[]
  conversations   Conversation[]

  @@unique([tenantId, whatsappWaId])
  @@unique([tenantId, normalizedPhone])
  @@unique([tenantId, email])
  @@index([tenantId, updatedAt])
  @@map("contacts")
}

model Lead {
  id             String            @id @default(cuid())
  tenantId       String
  contactId      String
  pipelineId     String?
  stageId        String?
  ownerUserId    String?
  title          String?
  sourceChannel  LeadSourceChannel
  status         LeadStatus        @default(OPEN)
  score          Int?
  firstInboundAt DateTime?
  lastInboundAt  DateTime?
  lastOutboundAt DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  version        Int               @default(1)
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact        Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  pipeline       Pipeline?         @relation(fields: [pipelineId], references: [id])
  stage          PipelineStage?    @relation(fields: [stageId], references: [id])
  ownerUser      User?             @relation("LeadOwner", fields: [ownerUserId], references: [id])
  conversations  Conversation[]

  @@index([tenantId, status, updatedAt])
  @@index([tenantId, ownerUserId, updatedAt])
  @@index([tenantId, pipelineId, stageId])
  @@map("leads")
}

model Conversation {
  id                    String               @id @default(cuid())
  tenantId              String
  contactId             String
  leadId                String?
  channel               ChannelType
  status                ConversationStatus   @default(OPEN)
  assigneeUserId        String?
  externalThreadKey     String?
  whatsappPhoneNumberId String?
  lastMessageAt         DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  version               Int                  @default(1)
  tenant                Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact               Contact              @relation(fields: [contactId], references: [id], onDelete: Cascade)
  lead                  Lead?                @relation(fields: [leadId], references: [id])
  assigneeUser          User?                @relation("ConversationAssignee", fields: [assigneeUserId], references: [id])
  whatsappPhoneNumber   WhatsappPhoneNumber? @relation(fields: [whatsappPhoneNumberId], references: [id], onDelete: SetNull)
  messages              Message[]

  @@unique([tenantId, channel, externalThreadKey])
  @@index([tenantId, channel, status, lastMessageAt])
  @@index([tenantId, assigneeUserId, lastMessageAt])
  @@index([tenantId, whatsappPhoneNumberId, lastMessageAt])
  @@map("conversations")
}

model Message {
  id                String           @id @default(cuid())
  tenantId          String
  conversationId    String
  direction         MessageDirection
  kind              MessageKind
  bodyText          String?
  mediaUrl          String?
  mediaMimeType     String?
  metaMessageId     String?
  externalStatus    String?
  pricingCategory   String?
  pricingType       String?
  currency          String?
  estimatedMetaCost Decimal?         @db.Decimal(12, 6)
  recipientCountry  String?
  deliveredAt       DateTime?
  readAt            DateTime?
  failedAt          DateTime?
  rawPayload        Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation      Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([tenantId, metaMessageId])
  @@index([tenantId, conversationId, createdAt])
  @@index([tenantId, deliveredAt])
  @@map("messages")
}

model WhatsappPhoneNumber {
  id                     String                 @id @default(cuid())
  tenantId               String
  wabaId                 String
  phoneNumberId          String                 @unique
  displayPhoneNumber     String?
  verifiedName           String?
  qualityRating          String?
  codeVerificationStatus String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  tenant                 Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations          Conversation[]
  webhookEvents          WhatsappWebhookEvent[]

  @@index([tenantId, wabaId])
  @@index([tenantId, displayPhoneNumber])
  @@map("whatsapp_phone_numbers")
}

model WhatsappWebhookEvent {
  id                    String                          @id @default(cuid())
  tenantId              String
  whatsappPhoneNumberId String
  eventType             WhatsappWebhookEventType
  processingStatus      WhatsappWebhookProcessingStatus @default(PENDING)
  objectType            String
  entryId               String?
  changeField           String
  eventKey              String
  externalMessageId     String?
  externalStatus        String?
  contactWaId           String?
  eventTimestamp        DateTime?
  rawPayload            Json
  processedAt           DateTime?
  errorMessage          String?
  createdAt             DateTime                        @default(now())
  updatedAt             DateTime                        @updatedAt
  tenant                Tenant                          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  whatsappPhoneNumber   WhatsappPhoneNumber             @relation(fields: [whatsappPhoneNumberId], references: [id], onDelete: Cascade)

  @@unique([tenantId, eventKey])
  @@index([tenantId, processingStatus, createdAt])
  @@index([tenantId, externalMessageId])
  @@index([whatsappPhoneNumberId, createdAt])
  @@map("whatsapp_webhook_events")
}

model Pipeline {
  id          String          @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isDefault   Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stages      PipelineStage[]
  leads       Lead[]

  @@unique([tenantId, name])
  @@index([tenantId, isDefault])
  @@map("pipelines")
}

model PipelineStage {
  id         String   @id @default(cuid())
  tenantId   String
  pipelineId String
  name       String
  slug       String
  color      String?
  position   Int
  isFinal    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  leads      Lead[]

  @@unique([pipelineId, slug])
  @@unique([pipelineId, position])
  @@index([tenantId, pipelineId])
  @@map("pipeline_stages")
}
